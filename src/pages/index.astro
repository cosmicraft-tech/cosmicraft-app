---
import AuroraScene from '../components/AuroraScene.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Cosmicraft Technologies — Future-proof software</title>
		<meta name="description" content="Senior software architecture for companies that need to scale — without over-engineering. Future-proof software, crafted to last.">

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
	</head>
	<body>
		<AuroraScene />

		<button id="lang-toggle" class="lang-toggle" aria-label="Trocar idioma" data-i18n="toggle">PT</button>

		<main>
			<svg class="logo" width="72" height="72" viewBox="0 0 100 100" aria-hidden="true">
				<circle cx="50" cy="50" r="38" fill="none" stroke="#818CF8" stroke-width="2.5"/>
				<g fill="none" stroke="#818CF8" stroke-width="2" stroke-linecap="round">
					<line x1="34" y1="66" x2="48" y2="48"/><line x1="48" y1="48" x2="62" y2="58"/>
					<line x1="62" y1="58" x2="70" y2="36"/><line x1="48" y1="48" x2="70" y2="36"/>
				</g>
				<circle cx="34" cy="66" r="3.5" fill="#818CF8"/><circle cx="48" cy="48" r="4" fill="#A5B4FC"/>
				<circle cx="62" cy="58" r="3.5" fill="#818CF8"/><circle cx="70" cy="36" r="5" fill="#A5B4FC"/>
			</svg>

			<p class="eyebrow">COSMICRAFT TECHNOLOGIES</p>
			<h1 data-i18n="tagline">Future-proof software, crafted to last.</h1>
			<p class="sub" data-i18n="sub">Senior software architecture for companies that need to scale — without over-engineering. 15+ years building platforms that last.</p>

			<div class="cta">
				<a class="btn btn-primary" href="https://wa.me/5511970560770" target="_blank" rel="noopener" data-i18n="cta1">Let's talk</a>
				<a class="btn btn-ghost" href="mailto:rafaellucio@cosmicraft.io" data-i18n="cta2">Email us</a>
			</div>
		</main>

		<footer>
			<nav class="f-links">
				<a href="mailto:rafaellucio@cosmicraft.io">Email</a>
				<a href="https://wa.me/5511970560770" target="_blank" rel="noopener">WhatsApp</a>
				<a href="https://www.linkedin.com/in/rafaelantoniolucio/" target="_blank" rel="noopener">LinkedIn</a>
				<a href="https://github.com/cosmicraft-tech" target="_blank" rel="noopener">GitHub</a>
			</nav>
			<p class="f-legal">Cosmicraft Technologies LTDA · CNPJ 58.320.157/0001-84 · São Paulo, Brasil</p>
			<p class="f-copy">© {new Date().getFullYear()} Cosmicraft Technologies. All rights reserved.</p>
		</footer>
	</body>
</html>

<style>
	body {
		margin: 0;
		padding: 0;
		min-height: 100vh;
		font-family: 'Inter', system-ui, sans-serif;
		color: #fafafa;
	}

	main {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		text-align: center;
		padding: 6rem 1.25rem 7rem;
		box-sizing: border-box;
	}

	.logo { margin-bottom: 1.5rem; }

	.eyebrow {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8rem;
		letter-spacing: 0.25em;
		color: #818cf8;
		margin: 0 0 1rem;
	}

	h1 {
		font-family: 'Space Grotesk', sans-serif;
		font-weight: 700;
		font-size: clamp(2.2rem, 6vw, 3.6rem);
		line-height: 1.05;
		margin: 0;
		max-width: 16ch;
	}

	.sub {
		font-size: clamp(1rem, 2.5vw, 1.25rem);
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.72);
		margin: 1.25rem 0 2rem;
		max-width: 46ch;
	}

	.cta { display: flex; gap: 0.85rem; flex-wrap: wrap; justify-content: center; }

	.btn {
		font-family: 'Inter', sans-serif;
		font-weight: 500;
		font-size: 1rem;
		padding: 0.8rem 1.6rem;
		border-radius: 10px;
		text-decoration: none;
		transition: transform 0.12s ease, background 0.15s ease;
	}
	.btn:active { transform: scale(0.98); }

	.btn-primary { background: #4f46e5; color: #fff; }
	.btn-primary:hover { background: #4338ca; }

	.btn-ghost {
		color: #fafafa;
		border: 1px solid rgba(255, 255, 255, 0.25);
	}
	.btn-ghost:hover { border-color: #818cf8; color: #c7d2fe; }

	.lang-toggle {
		position: fixed;
		top: 1.1rem;
		right: 1.1rem;
		z-index: 2;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8rem;
		letter-spacing: 0.1em;
		color: #fafafa;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.2);
		border-radius: 8px;
		padding: 0.45rem 0.8rem;
		cursor: pointer;
		backdrop-filter: blur(6px);
	}
	.lang-toggle:hover { border-color: #818cf8; }

	footer {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		z-index: 1;
		box-sizing: border-box;
		padding: 1.25rem 1rem;
		text-align: center;
		font-size: 0.8rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.55);
	}
	.f-links { display: flex; gap: 1.25rem; justify-content: center; flex-wrap: wrap; margin-bottom: 0.6rem; }
	.f-links a { color: #818cf8; text-decoration: none; }
	.f-links a:hover { text-decoration: underline; }
	.f-legal { margin: 0 0 0.3rem; }
	.f-copy { margin: 0; color: rgba(255, 255, 255, 0.4); }
</style>

<script>
	import { i18n, resolveLang, type Lang } from '../lib/i18n';

	function applyLang(lang: Lang) {
		const dict = i18n[lang];
		document.documentElement.lang = lang === 'pt' ? 'pt-BR' : 'en';
		document.querySelectorAll('[data-i18n]').forEach((el) => {
			const key = el.getAttribute('data-i18n');
			if (key && dict[key]) el.textContent = dict[key];
		});
		try { localStorage.setItem('cc-lang', lang); } catch (e) {}
	}

	let saved: string | null = null;
	try { saved = localStorage.getItem('cc-lang'); } catch (e) {}
	applyLang(resolveLang(saved, navigator.language));

	document.getElementById('lang-toggle')?.addEventListener('click', () => {
		const current = document.documentElement.lang.startsWith('pt') ? 'pt' : 'en';
		applyLang(current === 'pt' ? 'en' : 'pt');
	});
</script>
